# ═══════════════════════════════════════════════════════════════════════════════
# CREDIWISE ENVIRONMENT VARIABLES
# Copy this file to .env and fill in with your actual values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# 1. CREDIWISE APPLICATION DATABASES
# ─────────────────────────────────────────────────────────────────────────────────

DB_USERNAME=admin
DB_PASSWORD=change_me_in_production_12345!

# ─────────────────────────────────────────────────────────────────────────────────
# 2. KEYCLOAK IDENTITY PROVIDER SETUP
# ─────────────────────────────────────────────────────────────────────────────────

# Keycloak database
KC_DB_USERNAME=keycloak_admin
KC_DB_PASSWORD=keycloak_secure_password_12345!

# Keycloak admin credentials (for initial setup, change on first login)
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin_secure_password_12345!

# Keycloak hostname and proxy settings
KC_HOSTNAME=localhost:8180              # Local dev: localhost:8180
# KC_HOSTNAME=keycloak.crediwise.com    # Production: your actual domain
KC_HOSTNAME_STRICT=false                # Set to true in production with valid SSL cert
KC_PROXY=passthrough                    # passthrough | edge | reencrypt
KC_PROXY_ADDRESS_FORWARDING=true

# Keycloak HTTPS (set to true in production with valid certs)
KC_HTTPS_PROTOCOLS=TLSv1.3,TLSv1.2

# Keycloak logging level
KC_LOG_LEVEL=INFO                       # DEBUG for development, INFO for production

# Keycloak email configuration (for password reset emails)
# Leave empty for development (no emails sent)
# KC_MAIL_HOST=smtp.gmail.com
# KC_MAIL_PORT=587
# KC_MAIL_USERNAME=your-email@gmail.com
# KC_MAIL_PASSWORD=your-app-password
# KC_MAIL_FROM=noreply@crediwise.com
# KC_MAIL_SMTP_STARTTLS=true

# ─────────────────────────────────────────────────────────────────────────────────
# 3. QUARKUS MICROSERVICE OIDC CONFIGURATION
# These are shared across all services but can be overridden per-service
# ─────────────────────────────────────────────────────────────────────────────────

# Keycloak OIDC server (used by all Quarkus services)
QUARKUS_OIDC_AUTH_SERVER_URL=http://keycloak:8080/auth/realms/crediwise

# OIDC client credentials (per-service, see application.properties for overrides)
QUARKUS_OIDC_CLIENT_ID=crediwise-backend
QUARKUS_OIDC_CLIENT_SECRET=crediwise_backend_secret_key_12345

# ─────────────────────────────────────────────────────────────────────────────────
# 4. INDIVIDUAL MICROSERVICE CLIENT CREDENTIALS (Keycloak Client Credentials Grant)
# These are used for service-to-service gRPC communication
# ─────────────────────────────────────────────────────────────────────────────────

# Gestionnaire Service (also acts as auth server)
GESTIONNAIRE_CLIENT_ID=gestionnaire-service
GESTIONNAIRE_CLIENT_SECRET=gestionnaire_service_secret_12345

# Client Service
CLIENT_SERVICE_CLIENT_ID=client-service
CLIENT_SERVICE_CLIENT_SECRET=client_service_secret_12345

# Nouvelle Demande Service
NOUVELLE_DEMANDE_CLIENT_ID=nouvelle_demande_service
NOUVELLE_DEMANDE_CLIENT_SECRET=nouvelle_demande_service_secret_12345

# Analyse Service
ANALYSE_CLIENT_ID=analyse_service
ANALYSE_CLIENT_SECRET=analyse_service_secret_12345

# ─────────────────────────────────────────────────────────────────────────────────
# 5. FRONTEND REACT CONFIGURATION (used in frontend/.env)
# ─────────────────────────────────────────────────────────────────────────────────

VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=crediwise
VITE_KEYCLOAK_CLIENT_ID=crediwise-frontend

# API Base URL (points to backend/gestionnaire as API gateway)
VITE_API_BASE_URL=http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────────
# 6. APPLICATION PROFILES (OPTIONAL: for different environments)
# ─────────────────────────────────────────────────────────────────────────────────

# Set to 'prod' for production, 'dev' for development
QUARKUS_PROFILE=dev

# ─────────────────────────────────────────────────────────────────────────────────
# 7. OPTIONAL: JWT TOKEN REFRESH & SECURITY SETTINGS
# ─────────────────────────────────────────────────────────────────────────────────

# Token lifespan (Keycloak realm settings, but can be overridden here if needed)
KC_ACCESS_TOKEN_LIFESPAN=300            # 5 minutes
KC_REFRESH_TOKEN_LIFESPAN=1800          # 30 minutes

# ─────────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in values: nano .env (or use your editor)
# 3. Source variables: source .env (or: export $(cat .env | xargs))
# 4. Start services: docker-compose -f docker-compose.keycloak.yml up -d
#
# FOR PRODUCTION:
# - Use AWS Secrets Manager / Azure Key Vault / HashiCorp Vault instead of .env
# - Use strong passwords (min 16 chars, mix of uppercase, lowercase, digits, symbols)
# - Set KC_HOSTNAME_STRICT=true with valid SSL certificate
# - Set KC_HTTPS_PROTOCOLS=TLSv1.3
# - Enable KC_MAIL_* for email notifications
# - Set QUARKUS_PROFILE=prod
# ─────────────────────────────────────────────────────────────────────────────────
