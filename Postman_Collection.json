{
  "info": {
    "_postman_id": "crediwise-api",
    "name": "CrediWise Gestionnaire API",
    "description": "REST API for CrediWise Gestionnaire Microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "client_base_url",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "client_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "AUTHENTICATION",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('token', jsonData.accessToken);",
                  "    console.log('Token saved: ' + jsonData.accessToken.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"system@creditwise.com\",\n  \"password\": \"ChangeMe123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/health",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "GESTIONNAIRES",
      "item": [
        {
          "name": "Create Gestionnaire",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@creditwise.com\",\n  \"cin\": \"TN123456\",\n  \"numTelephone\": \"+21698765432\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"dateOfBirth\": \"1990-06-15\",\n  \"address\": \"12 Rue de la Paix, Tunis\",\n  \"password\": \"Pass123!\",\n  \"role\": \"CRO\",\n  \"agenceId\": \"100\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/gestionnaires",
              "host": ["{{base_url}}"],
              "path": ["api", "gestionnaires"]
            }
          }
        },
        {
          "name": "Get All Gestionnaires",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/gestionnaires",
              "host": ["{{base_url}}"],
              "path": ["api", "gestionnaires"]
            }
          }
        },
        {
          "name": "Update Gestionnaire",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numTelephone\": \"+21698765432\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"dateOfBirth\": \"1990-06-15\",\n  \"address\": \"12 Rue de la Paix, Tunis\",\n  \"role\": \"CRO\",\n  \"active\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/gestionnaires/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "gestionnaires", ":id"],
              "variable": [
                { "key": "id", "value": "00000000-0000-0000-0000-000000000002" }
              ]
            }
          }
        },
        {
          "name": "Move Gestionnaire to Agence",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agenceId\": \"101\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/gestionnaires/:id/agence",
              "host": ["{{base_url}}"],
              "path": ["api", "gestionnaires", ":id", "agence"],
              "variable": [
                { "key": "id", "value": "00000000-0000-0000-0000-000000000002" }
              ]
            }
          }
        },
        {
          "name": "Delete Gestionnaire",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/gestionnaires/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "gestionnaires", ":id"],
              "variable": [
                { "key": "id", "value": "00000000-0000-0000-0000-000000000002" }
              ]
            }
          }
        }
      ]
    },
