FROM nginx:1.27-alpine

# gettext for envsubst, openssl for self-signed cert generation
RUN apk add --no-cache gettext openssl

# Remove the default catch-all vhost that ships with the image
RUN rm /etc/nginx/conf.d/default.conf

# ── Config templates (envsubst processes *.template → *.conf at start) ──
COPY nginx.conf                   /etc/nginx/nginx.conf.template
COPY conf.d/upstream.conf         /etc/nginx/conf.d/upstream.conf.template
COPY conf.d/security-headers.conf /etc/nginx/conf.d/security-headers.conf.template
COPY conf.d/auth.conf             /etc/nginx/conf.d/auth.conf.template
# proxy-common.conf has no env vars — copy directly (no template step needed)
COPY conf.d/proxy-common.conf     /etc/nginx/conf.d/proxy-common.conf

# Directories that are volume-mounted at runtime:
#   /etc/nginx/ssl  ← TLS certificates (generated by entrypoint if absent)
#   /usr/share/nginx/html ← React SPA build (mount ./frontend/dist here)
RUN mkdir -p /etc/nginx/ssl /usr/share/nginx/html

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 80 443

ENTRYPOINT ["/entrypoint.sh"]
