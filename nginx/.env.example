# Copy to .env and fill in values before starting the nginx container

# Public domain name for the server_name directive
#NGINX_SERVER_NAME=app.crediwise.com

# The single origin allowed by CORS (must match your frontend URL exactly)
#CORS_ALLOWED_ORIGINS=https://app.crediwise.com

# Public Keycloak URL used in CSP connect-src and form-action
# (must be reachable by the browser, not just the Docker network)
#KEYCLOAK_PUBLIC_URL=https://auth.crediwise.com

# --- Dev overrides (copy to .env for local development) ---
 NGINX_SERVER_NAME=localhost
 CORS_ALLOWED_ORIGINS=http://localhost:3000
 KEYCLOAK_PUBLIC_URL=http://localhost:8180
